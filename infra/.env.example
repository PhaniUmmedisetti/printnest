# ─────────────────────────────────────────────────────────
# PrintNest — Environment Configuration
# Copy this file to infra/.env and fill in your values.
# NEVER commit infra/.env to git.
# ─────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────
POSTGRES_DB=printnest
POSTGRES_USER=printnest
POSTGRES_PASSWORD=change_me_strong_password

# ── MinIO (S3-compatible storage) ─────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=printfiles

# ── Backend API ───────────────────────────────────────────
# JWT signing key — must be at least 32 characters, random string
JWT_SIGNING_KEY=replace_with_32_plus_char_random_string_here

# JWT file token TTL in seconds (default: 120)
JWT_FILE_TOKEN_TTL_SECONDS=120

# Staff access-token TTL in minutes (default: 480 / 8 hours)
STAFF_AUTH_ACCESS_TOKEN_TTL_MINUTES=480

# Bootstrap super-admin credentials (created automatically on first startup)
STAFF_AUTH_BOOTSTRAP_USERNAME=admin
STAFF_AUTH_BOOTSTRAP_PASSWORD=replace_with_strong_bootstrap_password
STAFF_AUTH_BOOTSTRAP_DISPLAY_NAME=System Admin

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Storage endpoint (MinIO local)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_USE_HTTPS=false
