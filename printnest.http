# PrintNest API test flow (run top to bottom)
# Requires VS Code REST Client extension.
#
# Auth model:
# - Staff/Admin APIs: JWT bearer from /api/v1/staff/auth/login
# - Device APIs: HMAC headers (use tools/simulate-device.sh)
# - File JWT is issued by POST /api/v1/device/release after OTP validation

@baseUrl = http://localhost:5000
@staffUsername = admin
@staffPassword = replace-with-your-password
@staffAccessToken = paste-access-token-from-step-1

@storeId = store_supermart_01
@deviceId = dev_supermart_abc12345
@samplePdfPath = C:/Users/phani/Downloads/Pavan Kumar Madapathi BA - Resume.pdf

# Fill these after Step 4 / Step 6 / Step 11:
@sharedSecret = paste-shared-secret-from-step-4
@jobId = a6be1e5f-9386-4a4b-8bfd-a5bf13cede00
@uploadUrl = http://localhost:9000/printfiles/jobs/a6be1e5f-9386-4a4b-8bfd-a5bf13cede00.pdf?AWSAccessKeyId=minioadmin&Expires=1772142633&Signature=SpB%2FSPbtax9gHfs3kSiQH9uDJ%2FA%3D
@otp = paste-otp-from-step-11

###
# Step 0: Health check
GET {{baseUrl}}/health

###
# Step 1: Staff login (copy accessToken -> @staffAccessToken)
POST {{baseUrl}}/api/v1/staff/auth/login
Content-Type: application/json

{
  "username": "{{staffUsername}}",
  "password": "{{staffPassword}}"
}

###
# Step 2: Create store (first run -> 200, later runs may return 409 if already exists)
POST {{baseUrl}}/api/v1/admin/stores
Content-Type: application/json
Authorization: Bearer {{staffAccessToken}}

{
  "storeId": "{{storeId}}",
  "name": "SuperMart Hitech City",
  "address": "Hitech City, Hyderabad, Telangana 500081",
  "latitude": 17.4486,
  "longitude": 78.3908
}

###
# Step 3: List stores
GET {{baseUrl}}/api/v1/admin/stores
Authorization: Bearer {{staffAccessToken}}

###
# Step 4: Register device (copy sharedSecret from response into @sharedSecret)
# If device already exists, use Step 5 and your previous sharedSecret.
POST {{baseUrl}}/api/v1/admin/devices
Content-Type: application/json
Authorization: Bearer {{staffAccessToken}}

{
  "deviceId": "{{deviceId}}",
  "storeId": "{{storeId}}"
}

###
# Step 5: List devices
GET {{baseUrl}}/api/v1/admin/devices
Authorization: Bearer {{staffAccessToken}}

###
# Step 6: Create print job (copy jobId + upload.url)
POST {{baseUrl}}/api/v1/public/printjobs
Content-Type: application/json

{
  "fileName": "demo.pdf",
  "fileSizeBytes": 1024,
  "contentType": "application/pdf"
}

###
# Step 6 note:
# From Step 6 response, copy:
# - jobId -> @jobId
# - upload.url -> @uploadUrl
# IMPORTANT for local host:
#   replace "https://minio:9000" with "http://localhost:9000" in @uploadUrl

###
# Step 7: Upload PDF to MinIO (expect 200 + empty body)
PUT {{uploadUrl}}
Content-Type: application/pdf

< {{samplePdfPath}}

###
# Step 8: Finalize upload (expect {"status":"Uploaded"})
POST {{baseUrl}}/api/v1/public/printjobs/{{jobId}}/finalize
Content-Type: application/json

{}

###
# Step 9: Quote (expect status Quoted, minimum 500 paise)
POST {{baseUrl}}/api/v1/public/printjobs/{{jobId}}/quote
Content-Type: application/json

{
  "copies": 1,
  "color": "BW"
}

###
# Step 10: Mock payment (expect status Paid)
POST {{baseUrl}}/api/v1/public/printjobs/{{jobId}}/pay-mock
Content-Type: application/json

{}

###
# Step 11: Generate OTP (copy otp into @otp)
POST {{baseUrl}}/api/v1/public/printjobs/{{jobId}}/otp/generate
Content-Type: application/json

{}

###
# Step 12: Check job status
GET {{baseUrl}}/api/v1/public/printjobs/{{jobId}}

###
# Step 13: Public stores endpoint (no auth)
GET {{baseUrl}}/api/v1/public/stores

###
# Step 14: Run device flow using simulator (PowerShell -> WSL/Git-Bash)
# STORE_ID=store_supermart_01 bash tools/simulate-device.sh dev_supermart_abc12345 "<sharedSecret>" "<otp>" http://localhost:5000
#
# Expected simulator flow:
# - heartbeat ok
# - release ok
# - file download ok
# - printing-started ok
# - completed ok

###
# Optional: deactivate device
# PATCH {{baseUrl}}/api/v1/admin/devices/{{deviceId}}/deactivate
# Authorization: Bearer {{staffAccessToken}}

